{
  "name": "ai-operating-system",
  "private": true,
  "type": "module",
  "version": "0.28.1",
  "description": "AI Operating System — plataforma de governança para IA aplicada ao desenvolvimento de software",
  "license": "MIT",
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=22.13"
  },
  "scripts": {
    "dev": "pnpm --filter @aios/cli dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "node scripts/run-test-coverage.mjs",
    "test:coverage": "node scripts/run-test-coverage.mjs --coverage",
    "audit": "audit-ci --moderate",
    "prepare": "git config core.hooksPath .githooks",
    "sync:cursor-rules": "node scripts/sync-cursor-rules-from-policies.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "@vitest/coverage-v8": "^3.2.7",
    "audit-ci": "^7.1.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.1.0",
    "prettier": "^3.9.5",
    "turbo": "^2.5.4",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.64.0"
  }
}
