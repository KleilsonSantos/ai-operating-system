#!/usr/bin/env bash
# pre-push: bloqueia push direto para branches protegidas e valida
# vulnerabilidades em dependências antes de qualquer push.
# Bypass não recomendado; CI também aplica os gates.

set -euo pipefail

remote="${1:-}"
url="${2:-}"

echo "pre-push: verificando vulnerabilidades em dependências..."
pnpm audit

while read -r local_ref local_sha remote_ref remote_sha; do
  [[ -z "${local_ref:-}" ]] && continue
  if [[ "$remote_ref" == "refs/heads/main" || "$remote_ref" == "refs/heads/sandbox" ]]; then
    echo "pre-push: push direto para ${remote_ref#refs/heads/} é proibido."
    echo "pre-push: abra um PR para promover mudanças para branches protegidas."
    exit 1
  fi
done

echo "pre-push: ok!"
exit 0
